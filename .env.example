# =============================================================
# Cliente (Vite — vão no bundle, são públicas por design)
# =============================================================
# URL do projeto Supabase
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# Chave pública (anon) — Supabase dashboard → Settings → API → "anon public"
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# =============================================================
# Netlify Function /api/ocr-receipt (server-side apenas)
# NÃO use prefixo VITE_ — não devem ir no bundle
# =============================================================
# Mesma URL acima, sem o prefixo VITE_
SUPABASE_URL=https://<project-ref>.supabase.co
# Chave service_role (SECRETA — bypassa RLS)
# Supabase dashboard → Settings → API → "service_role secret"
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
# Chave da API Anthropic — console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================
# Opcional
# =============================================================
SENTRY_DSN=
